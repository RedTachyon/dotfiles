#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat >&2 <<'EOF'
Usage: toggle-passwordless-sudo {enable|disable|status}

Manages a dedicated sudoers drop-in for the current user.
EOF
}

target_user="${SUDO_USER:-${USER:-}}"

if [[ -z "$target_user" || "$target_user" == "root" ]]; then
    echo "Could not determine the non-root user to configure." >&2
    exit 1
fi

sudoers_file="/etc/sudoers.d/${target_user}-nopasswd"
sudoers_line="${target_user} ALL=(ALL) NOPASSWD: ALL"

enable() {
    tmp_file="$(mktemp)"
    trap 'rm -f "$tmp_file"' RETURN

    printf '%s\n' "$sudoers_line" >"$tmp_file"
    chmod 0440 "$tmp_file"

    sudo visudo -cf "$tmp_file" >/dev/null
    sudo install -o 0 -g 0 -m 0440 "$tmp_file" "$sudoers_file"
    sudo visudo -cf "$sudoers_file" >/dev/null

    echo "Passwordless sudo enabled for ${target_user}."
}

disable() {
    sudo rm -f "$sudoers_file"
    echo "Passwordless sudo disabled for ${target_user}."
}

status() {
    if sudo -n test -f "$sudoers_file" 2>/dev/null; then
        echo "Passwordless sudo is enabled for ${target_user}."
    elif sudo -n true 2>/dev/null; then
        echo "Passwordless sudo is disabled for ${target_user}."
    else
        echo "Passwordless sudo status is unknown; sudo authentication is required to check ${sudoers_file}."
        exit 1
    fi
}

case "${1:-}" in
    enable)
        enable
        ;;
    disable)
        disable
        ;;
    status)
        status
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        usage
        exit 2
        ;;
esac
